# Application Configuration
APP_NAME=microservice-boilerplate
APP_VERSION=1.0.0
APP_PORT=8080
APP_ENV=development

# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=microservice_db
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_SSL_MODE=disable
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=5

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Authentication Configuration
AUTH_JWT_SECRET=your-super-secret-jwt-key-change-in-production-please-use-strong-random-key
AUTH_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-please-use-strong-random-key
AUTH_ACCESS_TTL=15m
AUTH_REFRESH_TTL=168h

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_PREFIX=microservice
KAFKA_GROUP_ID=microservice-group
KAFKA_AUTO_OFFSET=earliest
KAFKA_MAX_RETRIES=3
KAFKA_RETRY_BACKOFF=1000